<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>404 — PetConnect</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;background:linear-gradient(135deg,var(--primary),#004a52);text-align:center;padding:2rem;">
  <div style="font-size:6rem;margin-bottom:1rem;animation:bounce 1s infinite alternate;">🐾</div>
  <h1 style="font-family:'Poppins',sans-serif;font-size:5rem;font-weight:900;color:#fff;line-height:1;">404</h1>
  <h2 style="color:rgba(255,255,255,.8);font-size:1.2rem;margin:.5rem 0 1rem;">This page ran away like an excited puppy!</h2>
  <p style="color:rgba(255,255,255,.5);margin-bottom:2rem;font-size:.9rem;">The page you're looking for doesn't exist.</p>
  <div style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;">
    <a href="/" class="btn btn-orange btn-lg"><i class="fas fa-home"></i> Go Home</a>
    <a href="/post-ad" class="btn btn-lg" style="background:rgba(255,255,255,.15);color:#fff;border:2px solid rgba(255,255,255,.3);"><i class="fas fa-plus"></i> Post an Ad</a>
  </div>
  <style>@keyframes bounce{from{transform:translateY(0)}to{transform:translateY(-18px)}}</style>
</body>
</html>
