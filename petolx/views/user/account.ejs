<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Account — PetConnect</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
<%- include('../partials/nav') %>
<%- include('../partials/flash') %>

<div class="container">
  <div class="page" style="max-width:820px;margin-left:auto;margin-right:auto;">

    <div class="page-title"><i class="fas fa-user-circle" style="color:var(--orange);"></i> My Account</div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;">

      <!-- Profile Card -->
      <div style="grid-column:1/-1;">
        <div class="card-white" style="display:flex;align-items:center;gap:1.25rem;flex-wrap:wrap;">
          <div style="width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--green));display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.8rem;font-weight:900;flex-shrink:0;">
            <%= user.name.charAt(0).toUpperCase() %>
          </div>
          <div>
            <div style="font-size:1.2rem;font-weight:800;color:var(--g900);"><%= user.name %></div>
            <div style="color:var(--g500);font-size:.85rem;"><%= user.email %></div>
            <div style="display:flex;gap:1rem;margin-top:.35rem;font-size:.82rem;color:var(--g500);flex-wrap:wrap;">
              <% if(user.city){ %><span><i class="fas fa-map-marker-alt"></i> <%= user.city %><% if(user.state){ %>, <%= user.state %><% } %></span><% } %>
              <span><i class="fas fa-list-alt"></i> <%= adCnt %> active ads</span>
              <span><i class="fas fa-comment-dots"></i> <%= msgCnt %> unread messages</span>
              <span><i class="fas fa-calendar"></i> Joined <%= new Date(user.createdAt).toLocaleDateString('en-IN',{month:'long',year:'numeric'}) %></span>
            </div>
          </div>
          <div style="margin-left:auto;display:flex;gap:.5rem;flex-wrap:wrap;">
            <a href="/my-ads" class="btn btn-gray btn-sm"><i class="fas fa-list-alt"></i> My Ads</a>
            <a href="/wishlist" class="btn btn-gray btn-sm"><i class="fas fa-heart"></i> Wishlist</a>
            <a href="/chat" class="btn btn-gray btn-sm"><i class="fas fa-comment-dots"></i> Messages</a>
          </div>
        </div>
      </div>

      <!-- Edit Profile -->
      <div class="fcard">
        <div class="fsect-title">Edit Profile</div>
        <form action="/account" method="POST">
          <div class="fg">
            <label class="fl">Full Name</label>
            <input type="text" name="name" class="fc" value="<%= user.name %>" required>
          </div>
          <div class="fg">
            <label class="fl">Email <span style="color:var(--g500);font-weight:400;">(cannot change)</span></label>
            <input type="email" class="fc" value="<%= user.email %>" disabled style="background:var(--g100);cursor:not-allowed;">
          </div>
          <div class="fg">
            <label class="fl">Phone Number</label>
            <input type="text" name="phone" class="fc" placeholder="+91 98765 43210" value="<%= user.phone||'' %>">
          </div>
          <div class="frow">
            <div class="fg">
              <label class="fl">City</label>
              <input type="text" name="city" class="fc" placeholder="City" value="<%= user.city||'' %>">
            </div>
            <div class="fg">
              <label class="fl">State</label>
              <input type="text" name="state" class="fc" placeholder="State" value="<%= user.state||'' %>">
            </div>
          </div>
          <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-save"></i> Save Profile</button>
        </form>
      </div>

      <!-- Change Password -->
      <div class="fcard">
        <div class="fsect-title">Change Password</div>
        <form action="/account/password" method="POST">
          <div class="fg">
            <label class="fl">Current Password</label>
            <input type="password" name="current" class="fc" placeholder="Your current password" required>
          </div>
          <div class="fg">
            <label class="fl">New Password</label>
            <input type="password" name="newpwd" class="fc" placeholder="Min 6 characters" required>
          </div>
          <div class="fg">
            <label class="fl">Confirm New Password</label>
            <input type="password" name="confirm" class="fc" placeholder="Repeat new password" required>
          </div>
          <button type="submit" class="btn btn-orange btn-block"><i class="fas fa-key"></i> Update Password</button>
        </form>

        <div class="hr"></div>
        <div style="background:var(--g50);border-radius:var(--r);padding:.9rem;font-size:.82rem;color:var(--g700);">
          <div style="font-weight:700;margin-bottom:.4rem;"><i class="fas fa-shield-alt" style="color:var(--green);"></i> Account Security</div>
          <div>✅ Password hashed with bcrypt</div>
          <div>✅ Session-based authentication</div>
          <div>✅ Role: <strong><%= user.role %></strong></div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div style="grid-column:1/-1;">
        <div class="card-white">
          <div style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--g500);margin-bottom:.9rem;">Quick Actions</div>
          <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
            <a href="/post-ad" class="btn btn-orange"><i class="fas fa-plus"></i> Post New Ad</a>
            <a href="/my-ads" class="btn btn-primary"><i class="fas fa-list-alt"></i> Manage My Ads</a>
            <a href="/chat" class="btn btn-gray"><i class="fas fa-comment-dots"></i> Messages</a>
            <a href="/wishlist" class="btn btn-gray"><i class="fas fa-heart"></i> My Wishlist</a>
            <form action="/logout" method="POST" style="margin:0;">
              <button type="submit" class="btn btn-red"><i class="fas fa-sign-out-alt"></i> Logout</button>
            </form>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script src="/js/main.js"></script>
</body>
</html>
