<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — PetConnect</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
<%- include('../partials/nav') %>
<%- include('../partials/flash') %>

<div class="container">
  <div class="page">
    <div class="card-white mb3" style="display:flex;align-items:center;gap:1.25rem;flex-wrap:wrap;">
      <div style="width:70px;height:70px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--green));display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.7rem;font-weight:900;flex-shrink:0;">
        <%= seller.name.charAt(0).toUpperCase() %>
      </div>
      <div>
        <div style="font-size:1.2rem;font-weight:800;"><%= seller.name %></div>
        <div style="font-size:.85rem;color:var(--g500);display:flex;gap:1rem;flex-wrap:wrap;margin-top:.25rem;">
          <% if(seller.city){ %><span><i class="fas fa-map-marker-alt"></i> <%= seller.city %><% if(seller.state){ %>, <%= seller.state %><% } %></span><% } %>
          <span><i class="fas fa-list-alt"></i> <%= listings.length %> active ad<%= listings.length!==1?'s':'' %></span>
          <span><i class="fas fa-calendar"></i> Member since <%= new Date(seller.createdAt).toLocaleDateString('en-IN',{month:'long',year:'numeric'}) %></span>
        </div>
      </div>
    </div>

    <div class="sec-title"><i class="fas fa-paw"></i> <%= seller.name.split(' ')[0] %>'s Active Listings</div>

    <% if(listings.length===0){ %>
    <div class="card-white empty"><div class="ei">📭</div><h3>No active listings</h3><p>This seller has no active ads right now.</p></div>
    <% }else{ %>
    <div class="grid">
      <% listings.forEach(l=>{ %>
      <a href="/pets/<%= l._id %>" style="text-decoration:none;display:contents;">
        <div class="lcard">
          <div class="lcard-img">
            <% if(l.images&&l.images[0]){ %><img src="/uploads/<%= l.images[0] %>" alt="<%= l.title %>" loading="lazy">
            <% }else{ %><%= CAT_EMOJI[l.category]||'🐾' %><% } %>
            <span class="ttag ttag-<%= l.listingType.toLowerCase() %>"><%= l.listingType %></span>
          </div>
          <div class="lcard-body">
            <div class="lcard-price <%= l.priceType==='Free'?'free':'' %>"><%= l.priceType==='Free'?'🤍 FREE':'₹'+l.price.toLocaleString('en-IN') %></div>
            <div class="lcard-title"><%= l.title %></div>
            <div class="lcard-meta"><span><i class="fas fa-map-marker-alt"></i> <%= l.city %></span><span><%= new Date(l.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %></span></div>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
    <% } %>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
