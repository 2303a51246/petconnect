<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Browse by Budget — PetConnect</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
<%- include('../partials/nav') %>
<%- include('../partials/flash') %>
<div class="container">
  <div class="page">
    <div class="page-title"><i class="fas fa-wallet" style="color:var(--orange);"></i> Browse by Budget</div>
    <p style="color:var(--g500);margin-bottom:1.5rem;font-size:.9rem;">Find pets that match your budget — from free adoption to premium breeds.</p>

    <div class="budget-grid">
      <% ranges.forEach(r=>{ %>
      <a href="<%= r.link %>" class="budget-card">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.75rem;">
          <div>
            <div style="font-size:1rem;font-weight:800;color:var(--primary);margin-bottom:.15rem;"><%= r.label %></div>
            <div style="font-size:.75rem;color:var(--g500);">
              <% if(r.type==='Adopt'){ %>Free adoption listings<% }else{ %>Sale listings in this range<% } %>
            </div>
          </div>
          <span style="background:<%= r.count>0?'#e8f5e9':'var(--g100)' %>;color:<%= r.count>0?'#2e7d32':'var(--g500)' %>;padding:.2rem .65rem;border-radius:20px;font-size:.78rem;font-weight:700;white-space:nowrap;"><%= r.count %> ad<%= r.count!==1?'s':'' %></span>
        </div>

        <% if(r.sample && r.sample.length > 0){ %>
        <div style="display:flex;gap:.4rem;margin-bottom:.75rem;">
          <% r.sample.forEach(s=>{ %>
          <div style="width:54px;height:46px;border-radius:var(--r2);overflow:hidden;background:var(--g100);display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;">
            <% if(s.images&&s.images[0]){ %><img src="/uploads/<%= s.images[0] %>" style="width:100%;height:100%;object-fit:cover;"><% }else{ %><%= CAT_EMOJI[s.category]||'🐾' %><% } %>
          </div>
          <% }) %>
          <% if(r.count > 4){ %>
          <div style="width:54px;height:46px;border-radius:var(--r2);background:var(--g200);display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;color:var(--g500);">+<%= r.count-4 %></div>
          <% } %>
        </div>
        <% } else { %>
        <div style="padding:.5rem 0;font-size:.82rem;color:var(--g500);"><i class="fas fa-inbox"></i> No listings in this range yet</div>
        <% } %>

        <div style="font-size:.82rem;color:var(--primary);font-weight:700;display:flex;align-items:center;gap:.35rem;">
          Browse <%= r.label %> <i class="fas fa-arrow-right"></i>
        </div>
      </a>
      <% }) %>
    </div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
