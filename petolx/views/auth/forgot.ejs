<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password — PetConnect</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
<%- include('../partials/flash') %>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <a href="/" class="logo" style="justify-content:center;font-size:1.8rem;">Pet<span>Connect</span></a>
    </div>

    <% if(typeof resetLink !== 'undefined' && resetLink){ %>
      <!-- Show the reset link -->
      <div style="text-align:center;margin-bottom:1.25rem;">
        <div style="font-size:2.5rem;margin-bottom:.5rem;">✅</div>
        <h2 style="font-size:1rem;font-weight:700;color:var(--green);">Reset link generated!</h2>
        <p style="font-size:.82rem;color:var(--g500);margin-top:.25rem;">For account: <strong><%= typeof resetEmail!=='undefined'?resetEmail:'' %></strong></p>
      </div>
      <div style="background:#e8f5e9;border-radius:var(--r);padding:1rem;margin-bottom:1rem;border-left:4px solid var(--green);">
        <p style="font-size:.78rem;font-weight:700;color:#1b5e20;margin-bottom:.5rem;"><i class="fas fa-link"></i> Click the link below to reset your password:</p>
        <a href="<%= resetLink %>" class="btn btn-green btn-block" style="word-break:break-all;">
          <i class="fas fa-key"></i> Reset My Password
        </a>
      </div>
      <p style="font-size:.75rem;color:var(--g500);text-align:center;">This link expires in 1 hour. In production, this link would be sent to your email.</p>
    <% } else { %>
      <!-- Show form -->
      <div style="text-align:center;margin-bottom:1.5rem;">
        <div style="font-size:2.5rem;margin-bottom:.5rem;">🔑</div>
        <h2 style="font-size:1.1rem;font-weight:700;">Forgot your password?</h2>
        <p style="font-size:.85rem;color:var(--g500);margin-top:.3rem;">Enter your registered email and we'll generate a reset link.</p>
      </div>
      <form action="/forgot-password" method="POST">
        <div class="fg">
          <label class="fl"><i class="fas fa-envelope"></i> Registered Email</label>
          <input type="email" name="email" class="fc" placeholder="you@example.com" required autofocus>
        </div>
        <button type="submit" class="btn btn-primary btn-block btn-lg">
          <i class="fas fa-paper-plane"></i> Get Reset Link
        </button>
      </form>
    <% } %>

    <div class="hr"></div>
    <p style="text-align:center;font-size:.88rem;">
      <a href="/login" style="color:var(--primary);font-weight:600;"><i class="fas fa-arrow-left"></i> Back to Login</a>
    </p>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
