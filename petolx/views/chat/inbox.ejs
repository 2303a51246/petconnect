<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Messages — PetConnect</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
<%- include('../partials/nav') %>
<%- include('../partials/flash') %>

<div class="container">
  <div class="page">
    <div class="page-title"><i class="fas fa-comment-dots" style="color:var(--orange);"></i> Messages <% if(totalUnread>0){ %><span style="background:var(--red);color:#fff;font-size:.72rem;padding:.15rem .55rem;border-radius:20px;font-family:'Inter',sans-serif;font-weight:800;"><%= totalUnread %> new</span><% } %></div>

    <div class="cinbox">
      <% if(convs.length===0){ %>
      <div class="card-white empty">
        <div class="ei">💬</div>
        <h3>No messages yet</h3>
        <p>When you contact a seller or someone messages you, conversations appear here.</p>
        <a href="/" class="btn btn-orange"><i class="fas fa-search"></i> Browse Pets</a>
      </div>
      <% }else{ %>
      <% convs.forEach(c=>{ %>
      <a href="/chat/<%= c.msg.listing._id %>/<%= c.other._id %>" style="text-decoration:none;">
        <div class="citem <%= c.unread>0?'unread':'' %>">
          <div class="cthumb">
            <% if(c.msg.listing.images&&c.msg.listing.images[0]){ %><img src="/uploads/<%= c.msg.listing.images[0] %>" alt="">
            <% }else{ %>🐾<% } %>
          </div>
          <div class="cavatar"><%= c.other.name.charAt(0).toUpperCase() %></div>
          <div style="flex:1;min-width:0;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.15rem;">
              <span style="font-weight:700;font-size:.88rem;"><%= c.other.name %></span>
              <span style="font-size:.72rem;color:var(--g500);"><%= new Date(c.msg.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %></span>
            </div>
            <div style="font-size:.78rem;color:var(--g500);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
              Re: <strong style="color:var(--primary);"><%= c.msg.listing.title %></strong>
            </div>
            <div style="font-size:.8rem;color:var(--g700);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:.1rem;"><%= c.msg.text %></div>
          </div>
          <% if(c.unread>0){ %>
          <div style="background:var(--orange);color:#fff;border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;font-size:.68rem;font-weight:800;flex-shrink:0;"><%= c.unread %></div>
          <% } %>
          <i class="fas fa-chevron-right" style="color:var(--g300);flex-shrink:0;font-size:.8rem;"></i>
        </div>
      </a>
      <% }) %>
      <% } %>
    </div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
